# SafeStay v2.3 — Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.

# ── Server Ports ───────────────────────────────────────────────────────────────
PORT=8000                          # FastAPI backend port
STREAMLIT_PORT=8501                # Streamlit frontend port

# ── YOLO Inference ─────────────────────────────────────────────────────────────
YOLO_CONFIDENCE=0.40               # Minimum confidence threshold [0.0–1.0]
YOLO_MODEL_PATH=models/yolov8n_safe.pt

# ── RSA Signing Keys ───────────────────────────────────────────────────────────
# If set, these PEM strings are used instead of auto-generating keys.
# Generate with:  openssl genrsa -out private.pem 2048
#                 openssl rsa -in private.pem -pubout -out public.pem
# Then paste the PEM file contents (with newlines as \n) here.
SAFESTAY_PRIVATE_KEY_PEM=
SAFESTAY_PUBLIC_KEY_PEM=

# ── Network Scanning ───────────────────────────────────────────────────────────
DEFAULT_NETWORK=auto               # 'auto' detects local subnet, or use e.g. 192.168.1.0/24
PASSIVE_SNIFF=true                 # true = stealth sniff | false = active ARP probe

# ── Report Output ──────────────────────────────────────────────────────────────
REPORT_OUTPUT_DIR=/tmp/safestay_reports

# ── macvendors.com API (optional — enhances vendor lookups) ───────────────────
MACVENDORS_API_KEY=

# ── Debug ──────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
